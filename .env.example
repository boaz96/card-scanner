# ===========================================================================
# card-scanner 환경변수 예시 — 실제 값은 .env 에 넣고 절대 커밋하지 마세요.
# 이 파일(.env.example)만 저장소에 올립니다. (값은 비워둠)
# ===========================================================================

# --- 서버 공통 ---
PORT=4000
NODE_ENV=development
# 프론트엔드 오리진(CORS 허용). 콤마로 여러 개 지정 가능.
CORS_ORIGIN=http://localhost:5173

# --- 1차: Anthropic Claude Vision ---
# https://console.anthropic.com 에서 발급
ANTHROPIC_API_KEY=
# 사용할 비전 지원 모델 (예: claude-3-5-sonnet-latest)
ANTHROPIC_MODEL=claude-3-5-sonnet-latest

# --- 2차 폴백/검증: Naver CLOVA OCR ---
# https://www.ncloud.com CLOVA OCR > Domain 생성 후 발급
CLOVA_OCR_INVOKE_URL=
CLOVA_OCR_SECRET_KEY=
# 폴백 OCR 사용 여부 (false면 LLM 단독)
USE_OCR_FALLBACK=true

# --- Google Sheets API v4 (서비스 계정) ---
# 서비스 계정 JSON의 client_email 과 private_key 를 사용.
# private_key 는 줄바꿈을 \n 으로 이스케이프해서 한 줄로 넣습니다.
GOOGLE_SHEETS_CLIENT_EMAIL=
GOOGLE_SHEETS_PRIVATE_KEY=
# 저장 대상 스프레드시트 ID (URL 의 /d/<여기>/edit)
GOOGLE_SHEETS_SPREADSHEET_ID=
# 기록할 시트(탭) 이름 = append/update 범위 기준('<탭>'!A:H)
GOOGLE_SHEETS_TAB_NAME=명함
